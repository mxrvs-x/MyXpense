{
  "expo": {
    "name": "MyXpense",
    "slug": "myxpense",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/MyXpense.png",

    "scheme": "myxpense",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/MyXpense.png"
    },

    "android": {
      "package": "com.mxrvs.myxpense",
      "versionCode": 1,

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#031d17"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/MyXpense.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/MyXpense.png",
          "resizeMode": "contain",
          "backgroundColor": "#ecfdf5",
          "dark": {
            "backgroundColor": "#031d17"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "974e3d00-eec1-4815-9248-d050319fe049"
      }
    },

    "owner": "mxrvs"
  }
}
